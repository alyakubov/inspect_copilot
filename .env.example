# Template — copy to .env and fill in your key.
# .env is gitignored; .env.example is committed.

# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Which Claude model to use for extraction + semantic Q&A.
# Recommended:
#   claude-sonnet-4-6   - best speed/cost for high-volume extraction (default)
#   claude-opus-4-7     - max quality, ~3x more expensive
#   claude-haiku-4-5    - cheapest, lower extraction accuracy
ANTHROPIC_MODEL=claude-sonnet-4-6
