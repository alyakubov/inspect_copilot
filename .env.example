# Template — copy to .env and fill in your key.
# .env is gitignored; .env.example is committed.

# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Which Claude model to use for extraction + semantic Q&A.
# Recommended:
#   claude-sonnet-4-6   - best speed/cost for high-volume extraction (default)
#   claude-opus-4-7     - max quality, ~3x more expensive
#   claude-haiku-4-5    - cheapest, lower extraction accuracy
ANTHROPIC_MODEL=claude-sonnet-4-6

# Sentence-embedding model for the semantic (RAG / Ask) index.
# Default BAAI/bge-m3: 8192-token context (a full report page embeds without
# truncation) and multilingual (EN/FR/NL). EMBED_DIM MUST equal the model's
# output dimension (bge-m3 = 1024); the loader asserts this. Changing either
# requires a re-index: python scripts/reindex_embeddings.py
# Lighter alternative: Snowflake/snowflake-arctic-embed-l-v2.0 (1024-dim, 8192).
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024
# Optional per-input token cap (well above a normal page). Bounds worst-case
# memory on a pathologically long OCR page.
EMBED_MAX_SEQ=2048

# Cesium Ion access token (free at https://cesium.com/ion).
# Scopes needed: assets:read (terrain + imagery + OSM Buildings).
# Used by the Buildings view's 3D tab. The view will show a friendly
# "no token" notice if this is empty.
CESIUM_ION_TOKEN=

# Optional single-user login gate. If BOTH are set, the app prompts for these
# credentials before showing anything. If either is empty/absent, no login is
# required.
USER_LOGIN=
USER_PASSWORD=

# Set to true to disable report deletion in the UI. The 🗑 Delete button still
# shows, but clicking it is blocked with a notice. Anything other than "true"
# (or absent) leaves deletion enabled.
NO_DELETE_REPORT=
